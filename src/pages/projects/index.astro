---
import BaseListing from "../../layouts/BaseListing.astro";
import GitHubOverview from "../../components/projects/GitHubOverview.astro";
import { PAGES } from "../../config";

if (PAGES.projects.isActive === false) {
    return Astro.redirect("/404");
}
---

<BaseListing
    collection="projects"
    title={PAGES.projects.title}
    subtitle={PAGES.projects.subtitle}
>
    <GitHubOverview slot="before-list" username="mich1803" />
</BaseListing>

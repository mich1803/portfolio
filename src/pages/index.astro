---
import { getEntry, render } from "astro:content";
import BaseLayout from "../layouts/BaseLayout.astro";
import FeaturedContent from "../components/layout/FeaturedContent.astro";
import { PAGES } from "../config";

// Load bio content
const bioEntry = await getEntry("bio", "bio");
const { Content: BioContent } = bioEntry
	? await render(bioEntry)
	: { Content: null };
---

<BaseLayout title={PAGES.home.title} sidebarVariant="about">
	<div class="container-narrow">
		{
			(PAGES.home.title || PAGES.home.subtitle) && (
				<header class="page-header">
					{PAGES.home.title && (
						<h1 class="page-title">{PAGES.home.title}</h1>
					)}
					{PAGES.home.subtitle && (
						<p class="page-subtitle">{PAGES.home.subtitle}</p>
					)}
				</header>
			)
		}
		<div class="prose">
			{BioContent ? <BioContent /> : <p>Loading bio...</p>}
		</div>
		<FeaturedContent
			class="mobile-about-featured-content"
			titleId="mobile-featured-content-title"
		/>
	</div>
</BaseLayout>

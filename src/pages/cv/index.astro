---
import { getEntry, render } from "astro:content";
import BaseLayout from "../../layouts/BaseLayout.astro";
import Timeline from "../../components/ui/Timeline.astro";
import { PAGES } from "../../config";

if (PAGES.cv.isActive === false) {
    return Astro.redirect("/404");
}

const cvEntry = await getEntry("cv", "cv");
if (!cvEntry) {
    throw new Error(
        "CV content not found. Please ensure src/content/cv.md exists.",
    );
}

const { Content } = await render(cvEntry);
const {
    experience = [],
    education = [],
    skills = [],
    languages = [],
    hobbies,
} = cvEntry.data;
---

<BaseLayout
    title={PAGES.cv.title}
    sidebarVariant="cv"
    sidebarCvDetails={{ skills, languages }}
>
    <header class="page-header">
        <h1 class="page-title">{PAGES.cv.title}</h1>
        <p class="page-subtitle">{PAGES.cv.subtitle}</p>
    </header>

    <div class="container-narrow">
        {
            experience.length > 0 && (
                <section class="section">
                    <h2 class="section-title border-b border-border pb-2">
                        Professional Experience
                    </h2>
                    <Timeline items={experience.map(exp => ({
                        title: exp.role,
                        subtitle: exp.institution,
                        period: exp.period,
                        description: exp.description
                    }))} />
                </section>
            )
        }

        {
            education.length > 0 && (
                <section class="section">
                    <h2 class="section-title border-b border-border pb-2">
                        Education
                    </h2>
                    <Timeline items={education.map(edu => ({
                        title: edu.degree,
                        subtitle: edu.institution,
                        period: edu.period,
                        description: edu.description,
                        thesis: edu.thesis
                    }))} />
                </section>
            )
        }

        {(skills.length > 0 || languages.length > 0 || hobbies) && (
            <div class="cv-mobile-details prose max-w-none">
                {skills.length > 0 && (
                    <section>
                        <h2>Skills Summary</h2>
                        <ul>
                            {skills.map((skill) => (
                                <li><strong>{skill.category}:</strong> {skill.items}</li>
                            ))}
                        </ul>
                    </section>
                )}
            </div>
        )}

        <div class="prose max-w-none">
            <Content />
        </div>

        {(languages.length > 0 || hobbies) && (
            <div class="cv-mobile-details prose max-w-none">
                {languages.length > 0 && (
                    <section>
                        <h2>Languages</h2>
                        <ul>
                            {languages.map((language) => (
                                <li><strong>{language.language}:</strong> {language.proficiency}</li>
                            ))}
                        </ul>
                    </section>
                )}
                {hobbies && (
                    <section>
                        <h2>Hobbies</h2>
                        <p>{hobbies}</p>
                    </section>
                )}
            </div>
        )}
    </div>
</BaseLayout>


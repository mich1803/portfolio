---
import { getEntry, render } from "astro:content";
import BaseLayout from "./BaseLayout.astro";
import BackLink from "../components/ui/BackLink.astro";
import Tag from "../components/ui/Tag.astro";
import Icon from "../components/ui/Icon.astro";
import { getDetailItem } from "../utils/adapters";
import { withBase } from "../utils/paths";
import { SITE } from "../config";

interface Props {
    collection: "publications" | "projects" | "posts";
    id: string;
}

const { collection, id } = Astro.props;
const entry = (await getEntry(collection, id)) as any;

if (!entry) return Astro.redirect(withBase("/404"));

const { Content, headings } = await render(entry);
const detail = getDetailItem(entry, collection);
const hasSidebarSummary = collection === "posts" || collection === "projects";
const sidebarHeadings = hasSidebarSummary
    ? headings.filter((heading) => heading.depth === 2 || heading.depth === 3)
    : [];
const publicationAbstract = collection === "publications" ? entry.data.abstract : undefined;
const publicationCitations = collection === "publications" && typeof entry.data.cited_by === "number"
    ? entry.data.cited_by
    : undefined;
const publicationSource = collection === "publications" && entry.data.source
    ? entry.data.source === "google-scholar" ? "Google Scholar" : entry.data.source
    : undefined;
const publicationYear = collection === "publications" && entry.data.date
    ? String(new Date(entry.data.date).getUTCFullYear())
    : undefined;
const publicationAuthorCount = collection === "publications" && entry.data.author
    ? entry.data.author.split(",").filter((author: string) => author.trim()).length
    : undefined;
const publicationStats = collection === "publications"
    ? [
        publicationYear ? { label: "Year", value: publicationYear } : null,
        { label: "Citations", value: String(publicationCitations ?? 0) },
        publicationAuthorCount !== undefined
            ? { label: "Authors", value: String(publicationAuthorCount) }
            : null,
    ].filter((stat): stat is { label: string; value: string } => stat !== null)
    : [];
const projectDemoUrl = collection === "projects" ? entry.data.demo_url : undefined;

const meta = [];
if (detail.date) meta.push({ label: "Date", value: detail.date, icon: "Calendar" });
if (detail.authors) meta.push({ label: "Author", value: detail.authors, icon: "User" });
if (detail.extraInput) {
    const icon = "Institution";
    const label = collection === "publications" ? "Journal" : "Info";
    meta.push({ label, value: detail.extraInput, icon });
}

const description = entry.data.description || detail.description || SITE.desc;
const ogImage = entry.data.image || SITE.ogImage;
---

<BaseLayout
    title={detail.title}
    description={description}
    ogImage={ogImage}
    ogType="article"
    sidebarVariant={hasSidebarSummary ? "article" : "publication"}
    sidebarSummaryTitle={collection === "projects" ? "In this project" : "In this post"}
    sidebarHeadings={sidebarHeadings}
    sidebarPublicationStats={publicationStats}
>
    <div class="flex justify-between items-center mb-4">
        <BackLink href={withBase(detail.backHref)} label={collection} />
        {collection !== "publications" && detail.externalUrl && (
            <a href={detail.externalUrl} target="_blank" rel="noopener noreferrer" class="link">
                {collection === "projects" ? "View source" : "View external"}
            </a>
        )}
    </div>

    <article>
        <h1 class="page-title mb-4">{detail.title}</h1>

        {meta.length > 0 && (
            <div class="card-meta mb-4">
                {meta.map((m: any) => (
                    <span class="flex items-center gap-1">
                        <Icon name={m.icon} size={14} />
                        <span>{m.value}</span>
                    </span>
                ))}
            </div>
        )}

        {detail.tags && detail.tags.length > 0 && (
            <div class="flex gap-2 flex-wrap mb-4">
                {detail.tags.map((tag: string) => (
                    <Tag name={tag} size="sm" />
                ))}
            </div>
        )}

        {publicationAbstract && (
            <section class="publication-abstract">
                <h2>Abstract</h2>
                <p>{publicationAbstract}</p>
            </section>
        )}

        <div class="prose">
            <Content />
        </div>

        {projectDemoUrl && (
            <div class="project-demo-cta">
                <a
                    href={projectDemoUrl}
                    target="_blank"
                    rel="noopener noreferrer"
                    class="project-demo-button"
                >
                    Launch the live simulation
                    <Icon name="ExternalLink" size={16} />
                </a>
            </div>
        )}

        {collection === "publications" && (
            <footer class="publication-details" aria-label="Publication details">
                <p class="publication-details-title">Publication details</p>
                <div class="publication-details-meta">
                    {publicationCitations !== undefined && (
                        <span><strong>Google Scholar citations:</strong> {publicationCitations}</span>
                    )}
                    {publicationSource && (
                        <span><strong>Source:</strong> {publicationSource}</span>
                    )}
                </div>
                {detail.externalUrl && (
                    <a href={detail.externalUrl} target="_blank" rel="noopener noreferrer" class="link">
                        Open publication
                    </a>
                )}
            </footer>
        )}

        <slot name="share" />
        <slot name="footer" />
    </article>
</BaseLayout>

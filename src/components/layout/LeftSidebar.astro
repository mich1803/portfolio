---
import { FEATURED_CONTENT, SOCIALS, SOCIAL_ICONS } from "../../config";
import { getCollection, getEntry } from "astro:content";
import Icon from "../ui/Icon.astro";
import { Image } from "astro:assets";
import { withBase } from "../../utils/paths";

const activeSocials = SOCIALS.filter((social) => social.isActive);

interface Props {
    compact?: boolean;
    showFeatured?: boolean;
    summaryTitle?: string;
    cvDetails?: {
        skills: Array<{ category: string; items: string }>;
        languages: Array<{ language: string; proficiency: string }>;
    };
    headings?: Array<{
        depth: number;
        slug: string;
        text: string;
    }>;
}

const {
    compact = false,
    showFeatured = false,
    summaryTitle = "In this post",
    cvDetails,
    headings = [],
} = Astro.props;

const featuredDateFormatter = new Intl.DateTimeFormat("en-US", {
    day: "numeric",
    month: "short",
    year: "numeric",
    timeZone: "UTC",
});

const bioCollection = await getCollection("bio");
const bio = bioCollection[0]?.data;

const featuredTypeLabels = {
    posts: "Blogpost",
    projects: "Project",
    publications: "Publication",
} as const;

const featuredItems = showFeatured
    ? (await Promise.all(
        FEATURED_CONTENT.map(async (selection) => {
            const entry = await getEntry(selection.collection, selection.id) as any;
            if (!entry) return null;

            return {
                title: entry.data.title,
                type: featuredTypeLabels[selection.collection],
                date: entry.data.date,
                tags: (entry.data.tags || []).slice(0, 2),
                description: entry.data.featured_description || entry.data.description,
                href: `/${selection.collection}/${entry.id}`,
            };
        }),
    )).filter((item): item is NonNullable<typeof item> => item !== null)
    : [];
---

<aside
    class:list={[
        "sidebar max-lg:flex-row max-lg:flex-wrap max-lg:gap-3 max-md:gap-2",
        { "sidebar-has-featured-content": showFeatured },
    ]}
>
    <div
        class="flex flex-col items-center text-center max-lg:flex-row max-lg:items-center max-lg:gap-3 max-lg:text-left max-md:gap-2"
    >
        {
            bio?.avatar && (
                <Image
                    src={withBase(bio.avatar)}
                    alt={`Avatar of ${bio.name}`}
                    width={160}
                    height={160}
                    densities={[1.5, 2]}
                    format="webp"
                    class="sidebar-avatar sidebar-avatar-light"
                    loading="eager"
                />
            )
        }

        {
            bio?.avatar && (
                <Image
                    src={withBase(bio.avatarDark || bio.avatar)}
                    alt={`Avatar of ${bio.name} for the dark theme`}
                    width={160}
                    height={160}
                    densities={[1.5, 2]}
                    format="webp"
                    class="sidebar-avatar sidebar-avatar-dark"
                    loading="eager"
                />
            )
        }

        <div class="flex flex-col items-center max-lg:items-start">
            {bio?.name && <h1 class="sidebar-name">{bio.name}</h1>}

            {
                !compact && (bio?.institution || bio?.location) && (
                    <div class="sidebar-info">
                        <Icon name="Institution" size={24} />
                        <span class="sidebar-affiliation-text">
                            {bio?.institution && <span>{bio.institution}</span>}
                            {bio?.location && (
                                <span class="sidebar-location">
                                    {bio.location}
                                </span>
                            )}
                        </span>
                    </div>
                )
            }

            {
                !compact && bio?.shortBio && (
                    <p class="sidebar-bio mt-2 max-md:hidden">
                        {bio.shortBio}
                    </p>
                )
            }

            <div
                class="mt-3 flex flex-wrap items-center justify-center gap-1 max-lg:justify-start"
            >
                {
                    activeSocials.map((social) => (
                        <a
                            href={social.href}
                            aria-label={social.linkTitle}
                            title={social.linkTitle}
                            target="_blank"
                            rel="noreferrer"
                            class="social-link"
                        >
                            <Icon
                                name={
                                    SOCIAL_ICONS[social.name] || social.name
                                }
                                size={24}
                            />
                        </a>
                    ))
                }
            </div>
        </div>
    </div>

    {
        cvDetails && (
            <section class="cv-sidebar-details" aria-label="Skills and languages">
                {cvDetails.skills.length > 0 && (
                    <div class="cv-sidebar-section">
                        <p class="cv-sidebar-title">Skills</p>
                        <dl class="cv-sidebar-list">
                            {cvDetails.skills.map((skill) => (
                                <div>
                                    <dt>{skill.category}</dt>
                                    <dd>{skill.items}</dd>
                                </div>
                            ))}
                        </dl>
                    </div>
                )}
                {cvDetails.languages.length > 0 && (
                    <div class="cv-sidebar-section">
                        <p class="cv-sidebar-title">Languages</p>
                        <dl class="cv-sidebar-list">
                            {cvDetails.languages.map((language) => (
                                <div>
                                    <dt>{language.language}</dt>
                                    <dd>{language.proficiency}</dd>
                                </div>
                            ))}
                        </dl>
                    </div>
                )}
            </section>
        )
    }

    {
        showFeatured && (
            <section class="featured-content" aria-labelledby="featured-content-title">
                <p id="featured-content-title" class="featured-content-title">
                    Featured content
                </p>
                <ol class="featured-content-list">
                    {featuredItems.map((item) => (
                        <li class="featured-content-item">
                            <a href={withBase(item.href)} class="featured-content-link">
                                {item.title}
                            </a>
                            <div class="featured-content-meta">
                                <span class="featured-content-type">{item.type}</span>
                                {item.date && (
                                    <time datetime={item.date}>
                                        {featuredDateFormatter.format(new Date(item.date))}
                                    </time>
                                )}
                            </div>
                            {item.description && (
                                <p class="featured-content-description">
                                    {item.description}
                                </p>
                            )}
                            {item.tags.length > 0 && (
                                <div class="featured-content-tags" aria-label="Tags">
                                    {item.tags.map((tag) => (
                                        <span>{tag}</span>
                                    ))}
                                </div>
                            )}
                        </li>
                    ))}
                </ol>
            </section>
        )
    }

    {
        compact && headings.length > 0 && (
            <nav class="post-toc" aria-label={summaryTitle}>
                <p class="post-toc-title">{summaryTitle}</p>
                <ol class="post-toc-list">
                    {headings.map((heading) => (
                        <li class:list={{ "post-toc-nested": heading.depth === 3 }}>
                            <a
                                href={`#${heading.slug}`}
                                class="post-toc-link"
                                data-post-toc-link
                                data-heading-id={heading.slug}
                            >
                                {heading.text}
                            </a>
                        </li>
                    ))}
                </ol>
            </nav>
        )
    }
</aside>

<script>
    let tocObserver: IntersectionObserver | undefined;

    function initPostTableOfContents() {
        tocObserver?.disconnect();

        const links = Array.from(
            document.querySelectorAll<HTMLAnchorElement>("[data-post-toc-link]"),
        );
        const sections = links
            .map((link) => {
                const id = link.dataset.headingId;
                return id ? document.getElementById(id) : null;
            })
            .filter((section): section is HTMLElement => section !== null);

        if (links.length === 0 || sections.length === 0) return;

        const setActiveLink = (id: string) => {
            links.forEach((link) => {
                const isActive = link.dataset.headingId === id;
                link.classList.toggle("is-active", isActive);
                if (isActive) link.setAttribute("aria-current", "location");
                else link.removeAttribute("aria-current");
            });
        };

        const updateActiveLink = () => {
            const activeSection = [...sections]
                .reverse()
                .find((section) => section.getBoundingClientRect().top <= 180);
            setActiveLink((activeSection ?? sections[0]).id);
        };

        tocObserver = new IntersectionObserver(updateActiveLink, {
            rootMargin: "-120px 0px -65% 0px",
            threshold: [0, 1],
        });
        sections.forEach((section) => tocObserver?.observe(section));
        updateActiveLink();
    }

    document.addEventListener("astro:page-load", initPostTableOfContents);
</script>

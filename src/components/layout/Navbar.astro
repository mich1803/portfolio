---
import { NAV_LINKS, PAGES } from "../../config";
import { withBase } from "../../utils/paths";

const normalizePath = (path: string) => path.replace(/\/+$/, "") || "/";
const currentPath = normalizePath(Astro.url.pathname);
---

<nav class="navbar">
    <ul class="nav-links">
        {
            NAV_LINKS.filter((link) => {
                const isHome = link.href === "/";
                const pageKey = isHome
                    ? "home"
                    : link.href.split("/").filter(Boolean)[0];
                const pageConfig = (PAGES as any)[pageKey];
                return link.isActive !== false && pageConfig?.isActive !== false;
            }).map((link) => {
                const href = withBase(link.href);
                const normalizedHref = normalizePath(href);
                const isActive = currentPath === normalizedHref || (
                    link.href !== "/" && currentPath.startsWith(`${normalizedHref}/`)
                );

                return (
                <li>
                    <a
                        href={href}
                        class={`nav-link ${isActive ? "active" : "inactive"}`}
                    >
                        {link.label}
                        <span class="nav-link-line" />
                    </a>
                </li>
                );
            })
        }
    </ul>
</nav>

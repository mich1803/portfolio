---
import Icon from "../ui/Icon.astro";
import { withBase } from "../../utils/paths";

interface Props {
    username?: string;
}

const { username = "mich1803" } = Astro.props;
const profileUrl = `https://github.com/${username}`;
---

<section
    class="github-overview"
    aria-labelledby="github-overview-title"
    data-github-overview
    data-username={username}
>
    <header class="github-overview-header">
        <div class="github-overview-identity">
            <img
                src={withBase("/images/michele_magrini.jpeg")}
                alt="Michele Magrini on GitHub"
                class="github-overview-avatar"
                width="72"
                height="72"
                loading="lazy"
                data-github-avatar
            />
            <div>
                <p class="github-overview-eyebrow">GitHub overview</p>
                <h2 id="github-overview-title" data-github-name>
                    Michele Magrini
                </h2>
                <a
                    href={profileUrl}
                    target="_blank"
                    rel="noopener noreferrer"
                    class="github-overview-handle"
                >
                    @{username}
                </a>
            </div>
        </div>

        <a
            href={profileUrl}
            target="_blank"
            rel="noopener noreferrer"
            class="github-profile-button"
        >
            <Icon name="Github" size={18} />
            View profile
            <Icon name="ExternalLink" size={15} />
        </a>
    </header>

    <dl class="github-stats" aria-label="GitHub profile statistics">
        <div class="github-stat-card">
            <dd data-github-stat="repositories" aria-busy="true">&mdash;</dd>
            <dt>Repositories</dt>
        </div>
        <div class="github-stat-card">
            <dd data-github-stat="followers" aria-busy="true">&mdash;</dd>
            <dt>Followers</dt>
        </div>
        <div class="github-stat-card">
            <dd data-github-stat="stars" aria-busy="true">&mdash;</dd>
            <dt>Total stars</dt>
        </div>
        <div class="github-stat-card">
            <dd data-github-stat="forks" aria-busy="true">&mdash;</dd>
            <dt>Total forks</dt>
        </div>
    </dl>

    <p class="github-overview-status" aria-live="polite" data-github-status>
        Loading live public GitHub statistics&hellip;
    </p>
</section>

<script>
    interface GitHubStats {
        repositories: number;
        followers: number;
        stars: number;
        forks: number;
        name: string;
        avatar: string;
    }

    interface GitHubCache {
        savedAt: number;
        stats: GitHubStats;
    }

    const numberFormatter = new Intl.NumberFormat("en-US");

    function getCachedData(key: string): GitHubCache | undefined {
        try {
            const cached = localStorage.getItem(key);
            return cached ? JSON.parse(cached) : undefined;
        } catch {
            return undefined;
        }
    }

    function cacheData(key: string, data: GitHubCache) {
        try {
            localStorage.setItem(key, JSON.stringify(data));
        } catch {
            // The overview remains usable when storage is disabled.
        }
    }

    async function fetchJson<T>(url: string, headers?: HeadersInit): Promise<T> {
        const response = await fetch(url, { headers });
        if (!response.ok) throw new Error(`Request failed with ${response.status}`);
        return response.json() as Promise<T>;
    }

    async function loadStats(username: string): Promise<GitHubStats> {
        const headers = {
            Accept: "application/vnd.github+json",
            "X-GitHub-Api-Version": "2022-11-28",
        };
        const [profile, repositories] = await Promise.all([
            fetchJson<{
                public_repos: number;
                followers: number;
                name: string | null;
                avatar_url: string;
            }>(`https://api.github.com/users/${username}`, headers),
            fetchJson<Array<{ stargazers_count: number; forks_count: number }>>(
                `https://api.github.com/users/${username}/repos?per_page=100&type=owner`,
                headers,
            ),
        ]);

        return {
            repositories: profile.public_repos,
            followers: profile.followers,
            stars: repositories.reduce((sum, repository) => sum + repository.stargazers_count, 0),
            forks: repositories.reduce((sum, repository) => sum + repository.forks_count, 0),
            name: profile.name || username,
            avatar: profile.avatar_url,
        };
    }

    function showStats(root: HTMLElement, stats: GitHubStats) {
        Object.entries(stats).forEach(([key, value]) => {
            if (typeof value !== "number") return;
            const output = root.querySelector<HTMLElement>(`[data-github-stat="${key}"]`);
            if (output) {
                output.textContent = numberFormatter.format(value);
                output.removeAttribute("aria-busy");
            }
        });

        const name = root.querySelector<HTMLElement>("[data-github-name]");
        const avatar = root.querySelector<HTMLImageElement>("[data-github-avatar]");
        if (name) name.textContent = stats.name;
        if (avatar) avatar.src = stats.avatar;
    }

    async function initGitHubOverview(root: HTMLElement) {
        if (root.dataset.initialized === "true") return;
        root.dataset.initialized = "true";

        const username = root.dataset.username;
        const status = root.querySelector<HTMLElement>("[data-github-status]");
        if (!username || !status) return;

        const cacheKey = `portfolio-github-overview-v2:${username}`;
        const cached = getCachedData(cacheKey);
        if (cached?.stats) showStats(root, cached.stats);

        try {
            const stats = await loadStats(username);
            showStats(root, stats);
            cacheData(cacheKey, { savedAt: Date.now(), stats });
            status.textContent = "Live statistics loaded from the public GitHub profile.";
        } catch {
            status.textContent = cached?.stats
                ? "Live statistics are unavailable; showing the latest saved values."
                : "GitHub statistics are temporarily unavailable. Visit the profile for current values.";
        }
    }

    function initGitHubOverviews() {
        document
            .querySelectorAll<HTMLElement>("[data-github-overview]")
            .forEach(initGitHubOverview);
    }

    document.addEventListener("astro:page-load", initGitHubOverviews);
</script>
